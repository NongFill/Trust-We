rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ผู้ใช้ทั่วไป แก้ไขข้อมูลของตัวเองได้
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && resource.data.storeId == request.auth.uid;
      }

      match /history/{historyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.resource.data.storeId == request.auth.uid;
      }
    }

    // ผู้ให้บริการ - ข้อมูลร้าน
    match /serve/{storeId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == storeId;

      match /orders/{orderId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      match /history/{historyId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
